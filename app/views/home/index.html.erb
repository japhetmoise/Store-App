<main class="dashboard">
  <header class="hero">
    <p class="eyebrow">Store Inventory Console</p>
    <h1>Manage Products, Stock In, and Stock Out</h1>
    <p class="subtitle">Use the forms below to create, update, view, and delete records in all tables.</p>
    <div id="status-message" class="status" role="status" aria-live="polite"></div>
  </header>

  <section class="panel" id="products-panel">
    <div class="panel-header">
      <h2>Products</h2>
      <button id="refresh-products" class="btn ghost" type="button">Refresh</button>
    </div>

    <form id="product-form" class="record-form">
      <input id="product-edit-id" type="hidden">
      <label>
        Name
        <input id="product-name" type="text" required>
      </label>
      <label>
        Price
        <input id="product-price" type="number" step="0.01" min="0" required>
      </label>
      <div class="form-actions">
        <button class="btn primary" type="submit">Save Product</button>
        <button id="cancel-product-edit" class="btn" type="button">Cancel</button>
      </div>
    </form>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Product ID</th>
            <th>Name</th>
            <th>Price</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="products-body"></tbody>
      </table>
    </div>
  </section>

  <section class="panel" id="store-ins-panel">
    <div class="panel-header">
      <h2>Store In</h2>
      <button id="refresh-store-ins" class="btn ghost" type="button">Refresh</button>
    </div>

    <form id="store-in-form" class="record-form">
      <input id="store-in-edit-id" type="hidden">
      <label>
        Product
        <select id="store-in-product-id" required></select>
      </label>
      <label>
        Quantity
        <input id="store-in-quantity" type="number" min="1" required>
      </label>
      <label>
        Date
        <input id="store-in-date" type="date" required>
      </label>
      <div class="form-actions">
        <button class="btn primary" type="submit">Save Store In</button>
        <button id="cancel-store-in-edit" class="btn" type="button">Cancel</button>
      </div>
    </form>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Product</th>
            <th>Quantity</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="store-ins-body"></tbody>
      </table>
    </div>
  </section>

  <section class="panel" id="store-outs-panel">
    <div class="panel-header">
      <h2>Store Out</h2>
      <button id="refresh-store-outs" class="btn ghost" type="button">Refresh</button>
    </div>

    <form id="store-out-form" class="record-form">
      <input id="store-out-edit-id" type="hidden">
      <label>
        Product
        <select id="store-out-product-id" required></select>
      </label>
      <label>
        Quantity
        <input id="store-out-quantity" type="number" min="1" required>
      </label>
      <label>
        Date
        <input id="store-out-date" type="date" required>
      </label>
      <div class="form-actions">
        <button class="btn primary" type="submit">Save Store Out</button>
        <button id="cancel-store-out-edit" class="btn" type="button">Cancel</button>
      </div>
    </form>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Product</th>
            <th>Quantity</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="store-outs-body"></tbody>
      </table>
    </div>
  </section>
</main>
